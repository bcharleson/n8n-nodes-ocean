{
  "name": "n8n-nodes-ocean",
  "version": "1.0.3",
  "description": "n8n community node for Ocean.io — lookalike company & people discovery, enrichment, reveal, and autocomplete",
  "keywords": [
    "n8n-community-node-package",
    "ocean.io",
    "lookalike",
    "prospecting",
    "lead generation",
    "data enrichment"
  ],
  "license": "MIT",
  "homepage": "https://github.com/bcharleson/n8n-nodes-ocean",
  "author": {
    "name": "Brandon Charleson",
    "email": "170791+bcharleson@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bcharleson/n8n-nodes-ocean.git"
  },
  "engines": {
    "node": ">=18.10",
    "pnpm": ">=9.1"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "dev:sync": "node scripts/sync-n8n-dev-env.js",
    "predev:server": "npm run build && node scripts/sync-n8n-dev-env.js",
    "dev:server": "nodemon --legacy-watch --config nodemon.json",
    "dev:full": "concurrently --kill-others \"npm run dev\" \"npm run dev:server\"",
    "verify": "npm run build && node scripts/verify-package.js && node scripts/verify-request-builders.js && node scripts/verify-n8n-load.js",
    "verify:audit": "node scripts/verify-audit.js",
    "verify:e2e": "node scripts/verify-e2e-api.js",
    "verify:all": "npm run verify:audit && npm run verify:e2e",
    "lint": "n8n-node lint",
    "release": "n8n-node release",
    "prepublishOnly": "npm run verify:audit"
  },
  "files": [
    "dist",
    "index.js",
    "README.md",
    "LICENSE.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/OceanApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Ocean/Ocean.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.29.0",
    "@n8n/node-cli": "^0.36.2",
    "@types/node": "^18.19.130",
    "concurrently": "^9.1.2",
    "eslint": "9.29.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^2.27.2",
    "nodemon": "^3.1.9",
    "release-it": "^20.2.0",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
